{
  "experimentalServices": {
    "frontend": { 
      "entrypoint": "frontend", 
      "routePrefix": "/", 
      "framework": "nextjs" 
    },
    "backend": { 
      "entrypoint": "backend/app",
      "routePrefix": "/api"
    }
  },
  "rewrites": [
    { 
      "source": "/api/(.*)", 
      "destination": "/backend/app/$1" 
    }
  ]
}