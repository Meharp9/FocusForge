{
  "experimentalServices": {
    "frontend": { 
      "entrypoint": "frontend", 
      "routePrefix": "/", 
      "framework": "nextjs" 
    },
    "backend": { 
      "entrypoint": "backend",
      "routePrefix": "/api" 
    }
  },
  "rewrites": [
    { 
      "source": "/api/(.*)", 
      "destination": "/backend/$1" 
    }
  ]
}